<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">



    <TextView
        android:id="@+id/tt1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27dp"
        android:text="FarmerEats"
        android:textColor="@color/black" />


    <LinearLayout
        android:id="@+id/ll1"
        android:layout_below="@+id/tt1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="28dp">


        <TextView
            android:id="@+id/text_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Signup 4 of 4"
            android:textSize="15sp"
            android:textColor="@color/My_secondary" />

        <TextView
            android:id="@+id/text_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Hours"
            android:textSize="38sp"
            android:textStyle="bold" />


    </LinearLayout>


    <TextView
        android:id="@+id/tt2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll1"
        android:layout_marginTop="25dp"
        android:text="@string/str_hours"
        android:textSize="15sp"
        android:textColor="@color/My_secondary"/>



    <LinearLayout
        android:id="@+id/ll2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tt2"
        android:layout_marginTop="25dp"
        android:orientation="horizontal"
        android:weightSum="7">



        <Button
            android:id="@+id/btnMon"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:backgroundTint="@color/my_tertiary"
            android:text="M"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnTue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="T"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnWed"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="W"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnThur"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Th"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnFri"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="F"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnSat"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="S"
            android:textSize="12sp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnSun"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="Su"
            android:textSize="12sp"
            android:padding="0dp"/>

    </LinearLayout>


    <GridLayout
        android:id="@+id/ll_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll2"
        android:layout_marginTop="25dp"
        android:columnCount="2">

        <Button
            android:id="@+id/btn_time1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="8:00am - 10:00am"
            android:backgroundTint="@color/my_tertiary"/>

        <Button
            android:id="@+id/btn_time2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="10:00am - 1:00pm"
            android:backgroundTint="@color/my_tertiary"/>

        <Button
            android:id="@+id/btn_time3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="1:00pm - 4:00pm"
            android:backgroundTint="@color/my_tertiary"/>

        <Button
            android:id="@+id/btn_time4"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="4:00pm - 7:00pm"
            android:backgroundTint="@color/my_tertiary"/>

        <Button
            android:id="@+id/btn_time5"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="3dp"
            android:text="7:00pm - 10:00pm"
            android:backgroundTint="@color/my_tertiary"/>

    </GridLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="475dp"
        android:layout_below="@+id/ll1"
        android:orientation="horizontal">

        <!-- Back Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_Back"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Back"
            android:backgroundTint="@color/My_secondary"/>

        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content"/>

        <!-- Continue Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_Continue"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Continue"
            android:backgroundTint="@color/btn_color1"/>
    </LinearLayout>








</RelativeLayout>