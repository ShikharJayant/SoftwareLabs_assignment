<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    >

    <TextView
        android:id="@+id/tt1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27dp"
        android:text="FarmerEats"
        android:textColor="@color/black"/>


    <LinearLayout
        android:id="@+id/ll1"
        android:layout_below="@id/tt1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="28dp">




        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password ?"

            android:textSize="38sp"
            android:textStyle="bold"
            />





    </LinearLayout>


    <LinearLayout
        android:id="@id/ll2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"

        android:orientation="horizontal"
        android:layout_below="@id/ll1">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remember your password?"
            android:textColor="@color/My_secondary"
            android:paddingRight="10dp"/>

        <TextView
            android:id="@+id/txt_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textColor="@color/btn_color1"
            android:textStyle="bold"/>


    </LinearLayout>







    <LinearLayout
        android:id="@+id/ll3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ll2"
        android:orientation="vertical"
        android:layout_marginTop="30dp">



        <!--        <TextView-->
        <!--            android:id="@+id/text_4"-->
        <!--            android:layout_width="match_parent"-->
        <!--            android:layout_height="wrap_content"-->
        <!--            android:layout_below="@+id/ll2"-->
        <!--            android:gravity="center"-->
        <!--            android:text="or login with"-->
        <!--            android:textSize="10sp"-->
        <!--            android:textColor="@color/My_secondary"-->
        <!--            />-->

        <EditText
            android:id="@+id/et_phoneno"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Phone Number"
            android:textSize="18sp"
            android:padding="10dp"
            android:backgroundTint="@color/my_tertiary"
            android:background="@drawable/rounded_corner"

            android:inputType="phone"
            android:maxLength="10"
            android:digits="0123456789"
            />





        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sendcode"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/btn_color1"
            android:text="Send Code"
            android:textSize="20sp"
            android:padding="10dp"/>

    </LinearLayout>
















</RelativeLayout>